{
  "name": "freee-demo-kit",
  "version": "0.1.0",
  "description": "freee sandbox seeder CLI — Load demo data into your freee test company",
  "type": "module",
  "bin": {
    "fdk": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist/",
    "presets/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "freee",
    "cli",
    "seed",
    "demo",
    "accounting"
  ],
  "author": "tackeyy",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
