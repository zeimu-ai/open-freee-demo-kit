# freee-demo-kit 設定ファイル
# このファイルを .env という名前でコピーして使ってください
# cp .env.example .env

# -------------------------------------------------------
# freee アプリの認証情報（必須）
# 取得方法: https://developer.freee.co.jp/startguide/starting-api
# -------------------------------------------------------

# freee アプリの Client ID
FREEE_CLIENT_ID=ここにClient IDを貼り付けてください

# freee アプリの Client Secret
FREEE_CLIENT_SECRET=ここにClient Secretを貼り付けてください
